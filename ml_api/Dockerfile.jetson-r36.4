# 1. JetPack 6 / L4T R36 base for Jetson Orin.
FROM nvcr.io/nvidia/l4t-jetpack:r36.4.0 AS darknet_builder

ENV DEBIAN_FRONTEND=noninteractive
ENV LIBRARY_PATH="${LIBRARY_PATH}:/usr/local/cuda/targets/aarch64-linux/lib:/usr/local/cuda/targets/aarch64-linux/lib/stubs"
ENV LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:/usr/local/cuda/targets/aarch64-linux/lib:/usr/local/cuda/lib64"

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    build-essential \
    gcc \
    g++ \
    make \
    cmake \
    git \
    curl \
    python3 \
    python3-pip \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /

# 2. Same Darknet revision used by Obico's old Jetson build.
RUN git clone https://github.com/AlexeyAB/darknet \
 && cd darknet \
 && git checkout 59c86222c5387bffd9108a21885f80e980ece234

# 3. Build CPU shared library.
RUN cd /darknet \
 && make clean \
 && make -j"$(nproc)" LIBSO=1 GPU=0 CUDNN=0 CUDNN_HALF=0 \
 && mv libdarknet.so libdarknet_cpu.so

# 4. Build GPU shared library.
#    Jetson Orin GPU architecture = sm_87.
#    ARCH is passed as make variable to avoid breaking Darknet's multiline Makefile ARCH block.
RUN cd /darknet \
 && make clean \
 && make -j"$(nproc)" \
      LIBSO=1 \
      GPU=1 \
      CUDNN=0 \
      CUDNN_HALF=0 \
      ARCH="-gencode arch=compute_87,code=sm_87" \
 && mv libdarknet.so libdarknet_gpu.so


# 5. Runtime image.
FROM nvcr.io/nvidia/l4t-jetpack:r36.4.0

ENV DEBIAN_FRONTEND=noninteractive
ENV LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:/usr/local/cuda/targets/aarch64-linux/lib:/usr/local/cuda/lib64"
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    python3 \
    python3-pip \
 && rm -rf /var/lib/apt/lists/*

COPY --from=darknet_builder /darknet /darknet

WORKDIR /app

COPY requirements.txt ./

RUN python3 -m pip install --upgrade pip \
 && python3 -m pip install --no-cache-dir opencv_python_headless \
 && python3 -m pip install --no-cache-dir -r requirements.txt

COPY . /app

RUN mkdir -p /model_cache/ml_api/darknet /model_cache/ml_api/onnx \
 && echo 'Downloading the latest failure detection AI model in Darknet format...' \
 && curl -L -o /model_cache/ml_api/darknet/model-weights.darknet "$(cat model/model-weights.darknet.url | tr -d '\r')" \
 && echo 'Downloading the latest failure detection AI model in ONNX format...' \
 && curl -L -o /model_cache/ml_api/onnx/model-weights.onnx "$(cat model/model-weights.onnx.url | tr -d '\r')"

EXPOSE 3333
